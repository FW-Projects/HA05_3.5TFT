#include "output_handle.h"
#include "work_handle.h"
#include "lcd_handle.h"
uint8_t off_set_buff[41] = {22, 21, 21, 21, 21, 21, 21, 21, 20, 20, 21, 21, 21, 20, 19, 19, 19, 18, 18, 17, 17, 16, 16, 15, 14, 13, 12, 11, 11, 10, 9, 9, 8, 8, 7, 6, 5, 4, 3, 1, 0};


/* 继电器开启完成标志位 */
uint8_t relay_open_flag = FALSE;
uint16_t relay_open_delay = RELAY_OPEN_TIME;
void fan_control(void)
{
    static uint8_t close_flag = 0;//上电默认关闭风扇，必须运行过一次后才能打开。
    static uint8_t wind_value;

    if (swork.state == STOP)
    {
        if (close_flag)
        {
            if (actual_temp >= 250)
            {
                /* 打开风扇 */
                tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
                tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, 143);
            }
            else if (actual_temp >= 70 && actual_temp < 250)
            {
                wind_value = actual_temp * 0.4;
                /* 打开风扇 */
                tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
                tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, wind_value * 1.13 + 30);
            }
            else
            {
                /* 打开风扇 */
                tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
                tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, 20);
            }
        }
    }
    else if (swork.state == WORKING)
    {
        if (set_wind >= 200)
        {
            set_wind = 200;
        }
        else if (set_wind <= 0)
        {
            set_wind = 0;
        }

        tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
        tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, set_wind * 1.13 + 30);
        close_flag = 1;
    }
    else if (swork.state == OVER_TEMP_ERR)
    {
        /* 打开风扇 */
        tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
        tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, 200);
    }
    else if (swork.state == LOW_TEMP_ERR)
    {
        /* 关闭风扇 */
        tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, FALSE);
        tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, 0);
        close_flag = 0;
    }
    else if (swork.state == COLD_MODE)
    {
        close_flag = 1;
        /* 打开风扇 */
        tmr_channel_enable(TMR2, TMR_SELECT_CHANNEL_2, TRUE);
        tmr_channel_value_set(TMR2, TMR_SELECT_CHANNEL_2, cold_mode_set_wind * 1.13 + 30);
    }
}

void hot_control(void)
{
    //volatile static int16_t relay_open_delay = RELAY_OPEN_TIME;
    if (
        swork.state == INIT          ||
        swork.state == SLEEP         ||
        swork.state == OVER_TEMP_ERR ||
        swork.state == LOW_TEMP_ERR)
    {
        /* 关闭可控硅 */
        tmr_counter_enable(TMR5, FALSE);
        tmr_channel_value_set(TMR5, TMR_SELECT_CHANNEL_2, 0);
        /* 关闭继电器 */
        gpio_bits_reset(GPIOC, GPIO_PINS_14);
        /* 恢复标志位 */
        relay_open_flag = FALSE;
        /* 恢复延时时间 */
        relay_open_delay = RELAY_OPEN_TIME;
    }
    else if (swork.state == WORKING)
    {
        static uint8_t first_in = FALSE;
        /* 开启继电器 */
        gpio_bits_set(GPIOC, GPIO_PINS_14);

        /* 等待延时结束（300ms） */
        if (relay_open_flag == FALSE)
        {
            relay_open_delay --;
        }

        /* 继电器开启完成标志位置1 */
        if (!relay_open_delay)
        {
            relay_open_delay = 0;
            relay_open_flag = TRUE;
        }
    }
}

uint8_t linear_correction(uint16_t user_set_temp)
{
	
    static uint8_t n = 0;
    static uint16_t check_start = 0;
    static uint8_t check_value = 0;

    if (user_set_temp < 300)
    {
        check_value = 0;
        check_start = 100;

        for (n = 0; n < 20; n++)
        {
            if (user_set_temp < (check_start + check_value))
            {
                return (off_set_buff[n]);
            }
            else
            {
                check_start += 10;
            }
        }
    }
    else
    {
        check_value = 0;
        check_start = 300;
        for (n = 0; n < 20; n++)
        {
        if (user_set_temp < (check_start + check_value))
        {
            return (off_set_buff[n]);
        }
        else
        {
            check_start += 10;
        }
	}
    }

    return (off_set_buff[n]);

}

uint16_t temp_get(void)
{
    static uint16_t temp;
    temp = get_adcval(ADC_CHANNEL) >> 2;
    return temp;
}

uint16_t temp_get_filter_average(void)
{
    static uint16_t temp;
    temp = (get_adcval_average(ADC_CHANNEL, 80) >> 2);
    return temp;
}

uint16_t temp_get_filter_middleValue(void)
{
    static uint16_t temp;
    temp =  middleValueFilter() >> 2;
    return temp;
}

uint16_t temp_get_filter_move_average(void)
{
    static uint16_t temp;
    temp =  moveAverageFilter() >> 2;

    if (temp >= 1023)
    {
        temp = 1023;
    }

    return temp;
}

uint16_t temp_get_filter_mode(void)
{
    static uint16_t temp;
    temp = modeFilter() >> 2;
    return temp;
}

uint16_t temp_get_filter_max_count(void)
{
    static uint16_t temp;
    temp = max_count_filter() >> 2;
    return temp;
}

uint16_t temp_get_average(void)
{
    static uint16_t temp;
    temp = average(10) >> 2;
    return temp;
}



