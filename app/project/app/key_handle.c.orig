    }
}

static KEY keys[] =
{
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_key_ch1},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_key_ch2},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_key_ch3},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_key_ch4},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_temp_add_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_temp_reduce_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_air_add_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_air_reduce_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_set_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_hel1_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_hel2_key},
    {KS_RELEASE, 0, KEY_CYCLE_TIME, get_hel3_key},
};

KEY_EVENT key_event[KEY_NUMBER] =
{
    KE_PRESS,
    KE_RELEASE,
    KE_LONG_PRESS,
    KE_LONG_RELEASE,
    KE_NONE,
};


void KeyProc(void)
{
    for (uint8_t i = 0; i < KEY_NUMBER; i++)
    {
        key_event[i] = key_event_check(&keys[i], LONG_PRESS_TIME);
    }
}


void key_handle(void)
{
    static  handle_event event = END_EVENT;
    static uint8_t delay_time = 5;
    static uint16_t hel1_time = HEL_TIME;
    static uint8_t hel1_flag = FALSE;
    static uint8_t hel1_mode = 0;   //0:set temp  1:set wind
    static uint8_t set_done = FALSE;

    if (swork.state == SLEEP)
    {
        if (get_key_ch1()         == K_PRESS || \
                get_key_ch2()         == K_PRESS || \
                get_key_ch3()         == K_PRESS || \
                get_key_ch4()         == K_PRESS || \
                get_temp_add_key()    == K_PRESS || \
                get_temp_reduce_key() == K_PRESS || \
                get_air_add_key()     == K_PRESS || \
                get_air_reduce_key()  == K_PRESS || \
                get_set_key()         == K_PRESS || \
                get_hel1_key()        == K_PRESS || \
                get_hel2_key()        == K_PRESS || \
                get_hel3_key()        == K_PRESS)
        {
            swork.state = STOP;
        }
    }

    KeyProc();
    /* зщКЯМќЁЂГЄАДАДМќ */
#if 1

    /* ЛжИДГіГЇЩшжУ */
    if (key_event[2] == KE_LONG_PRESS && key_event[8] == KE_LONG_PRESS && key_event[3] == KE_LONG_PRESS
            && set_done == FALSE)//ch3ЁЂsetЁЂch4БЛГЄАД
    {
        reset_flag = TRUE;
        event = SYSTEM_RESET_EVENT;
        set_done = TRUE;
    }
    else if (key_event[8] == KE_LONG_PRESS && set_done == FALSE) //ЩшжУАДМќБЛГЄАД
    {
        static uint8_t scan_time = 10;
        scan_time -- ;

        if (!scan_time)
        {
            scan_time = 10;

            if (key_event[0] == KE_LONG_PRESS && set_done == FALSE) //ЩшжУМгCH1БЛГЄАД
            {
                //ЧаЛЛЩуЪЯЖШЯдЪО
                display_mode++;
                beep_flag = BEEP_LONG;

                if (display_mode >= 3)
                {
                    display_mode = 1;
                }

                set_done = TRUE;
            }
            else if (key_event[1] == KE_LONG_PRESS && set_done == FALSE) //ЩшжУМгCH2БЛГЄАД
            {
                //НјШыЮТЖШаЃзМ(БиаыЪЧдкдЫааФЃЪНЯТВХФмЩшжУ)
                if (swork.state == WORKING)
                {
                    set_calibration_temp_flag = TRUE;
                    beep_flag = BEEP_LONG;
                    set_done = TRUE;
                }
            }
            else if (key_event[2] == KE_LONG_PRESS && set_done == FALSE) //ЩшжУМгCH3БЛГЄАД
            {
                //НјШыЮТЖШЫјЖЈ
                beep_flag = BEEP_LONG;
                lock_mode++;

                if (lock_mode >= 3)
                {
                    lock_mode = 1;
                }

                if (lock_mode == 1)
                {
                    show_on_flag = 1;
                }
                else if (lock_mode == 2)
                {
                    show_off_flag = 1;
                }

                set_done = TRUE;
            }
            else if (key_event[3] == KE_LONG_PRESS && set_done == FALSE) //ЩшжУМгCH4БЛГЄАД
            {
                //НјШыЗфУљЦїПЊЙиЩшжУ
                beep_flag = BEEP_LONG;
                speak_mode++;

                if (speak_mode >= 3)
                {
                    speak_mode = 1;
                }

                if (speak_mode == 1)
                {
                    show_off_flag = 1;
                }
                else if (speak_mode == 2)
                {
                    show_on_flag = 1;
                }

                set_done = TRUE;
            }
            else if (key_event[0] == KE_NONE && key_event[1] == KE_NONE && key_event[2] == KE_NONE
                     && key_event[3] == KE_NONE && set_done == FALSE)//жЛгаЩшжУБЛГЄАДЪБ
            {
                if (!time_countdown_flag)
                {
                    event = SET_TIME_EVENT;
                    set_done = TRUE;
                }
            }
        }
    }
    else if (key_event[0] == KE_LONG_PRESS && set_done == FALSE)//CH1АДМќБЛГЄАД
    {
        static uint8_t scan_time = 10;
        scan_time -- ;

        if (!scan_time)
        {
            scan_time = 10;

            if (key_event[8] == KE_LONG_PRESS && set_done == FALSE)  //CH1КЭЩшжУМќБЛГЄАД
            {
                //ЧаЛЛЩуЪЯЖШЯдЪО
                display_mode++;
                beep_flag = BEEP_LONG;

                if (display_mode >= 3)
                {
                    display_mode = 1;
                }

                set_done = TRUE;
            }
            else if (key_event[8] == KE_NONE && set_done == FALSE)//жЛгаCH1МќБЛГЄАД
            {
                event = SET_CH1_EVENT;
                set_done = TRUE;
            }
        }
    }
    else if (key_event[1] == KE_LONG_PRESS && set_done == FALSE)//CH2АДМќБЛГЄАД
    {
        static uint8_t scan_time = 10;
        scan_time -- ;

        if (!scan_time)
        {
            scan_time = 10;

            if (key_event[8] == KE_LONG_PRESS && set_done == FALSE) //CH2КЭЩшжУМќБЛГЄАД
            {
                //НјШыЮТЖШаЃзМ(БиаыЪЧдкдЫааФЃЪНЯТВХФмЩшжУ)
                if (swork.state == WORKING)
                {
                    set_calibration_temp_flag = TRUE;
                    beep_flag = BEEP_LONG;
                    set_done = TRUE;
                }
            }
            else if (key_event[8] == KE_NONE && set_done == FALSE)//жЛгаCH2МќБЛГЄАД
            {
                event = SET_CH2_EVENT;
            }
        }
    }
    else  if (key_event[2] == KE_LONG_PRESS && set_done == FALSE)//CH3АДМќБЛГЄАД
    {
        static uint8_t scan_time = 10;
        scan_time -- ;

        if (!scan_time)
        {
            scan_time = 10;

            if (key_event[8] == KE_NONE && set_done == FALSE)//жЛгаCH3МќБЛГЄАД
            {
                event = SET_CH3_EVENT;
                set_done = TRUE;
            }
            else if (key_event[8] == KE_LONG_PRESS && set_done == FALSE) //CH3КЭЩшжУМќБЛГЄАД
            {
                //НјШыЮТЖШЫјЖЈ
                beep_flag = BEEP_LONG;
                lock_mode++;

                if (lock_mode >= 3)
                {
                    lock_mode = 1;
                }

                if (lock_mode == 1)
                {
                    show_on_flag = 1;
                }
                else if (lock_mode == 2)
                {
                    show_off_flag = 1;
                }

                set_done = TRUE;
            }
        }
    }
    else if (key_event[3] == KE_LONG_PRESS && set_done == FALSE)//CH4АДМќБЛГЄАД
    {
        static uint8_t scan_time = 10;
        scan_time -- ;

        if (!scan_time)
        {
            scan_time = 10;

            if (key_event[8] == KE_LONG_PRESS && set_done == FALSE) //CH3КЭЩшжУМќБЛГЄАД
            {
                //НјШыЗфУљЦїПЊЙиЩшжУ
                beep_flag = BEEP_LONG;
                speak_mode++;

                if (speak_mode >= 3)
                {
                    speak_mode = 1;
                }

                if (speak_mode == 1)
                {
                    show_off_flag = 1;
                }
                else if (speak_mode == 2)
                {
                    show_on_flag = 1;
                }

                set_done = TRUE;
            }
            else if (key_event[8] == KE_NONE && set_done == FALSE)//жЛгаCH4МќБЛГЄАД
            {
                event = SET_CH4_EVENT;
                set_done = TRUE;
            }
        }
    }

#endif

    /* ЕЅЛїАДМќ */
    if (key_event[0] == KE_PRESS && set_done == FALSE)
    {
        /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
        if (!set_calibration_temp_flag)
        {
            show_ch_value_flag = TRUE;
            ch = 1;
            set_temp = set_temp_ch1;
            set_wind = set_wind_ch1;
            set_time = set_time_ch1;
            event = VALUE_RESET_EVENT;
            set_done = TRUE;
            set_temp_f = (9 * set_temp / 5 + 32);
        }
    }
    else if (key_event[1] == KE_PRESS && set_done == FALSE)
    {
        /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
        if (!set_calibration_temp_flag)
        {
            show_ch_value_flag = TRUE;
            ch = 2;
            set_temp = set_temp_ch2;
            set_wind = set_wind_ch2;
            set_time = set_time_ch2;
            event = VALUE_RESET_EVENT;
            set_done = TRUE;
            set_temp_f = (9 * set_temp / 5 + 32);
        }
    }
    else if (key_event[2] == KE_PRESS && set_done == FALSE)
    {
        /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
        if (!set_calibration_temp_flag)
        {
            show_ch_value_flag = TRUE;
            ch = 3;
            set_temp = set_temp_ch3;
            set_wind = set_wind_ch3;
            set_time = set_time_ch3;
            event = VALUE_RESET_EVENT;
            set_done = TRUE;
            set_temp_f = (9 * set_temp / 5 + 32);
        }
    }
    else if (key_event[3] == KE_PRESS && set_done == FALSE)
    {
        /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
        if (!set_calibration_temp_flag)
        {
            show_ch_value_flag = TRUE;
            ch = 4;
            set_temp = set_temp_ch4;
            set_wind = set_wind_ch4;
            set_time = set_time_ch4;
            event = VALUE_RESET_EVENT;
            set_done = TRUE;
            set_temp_f = (9 * set_temp / 5 + 32);
        }
    }
    else if (key_event[4] == KE_PRESS && set_done == FALSE)
    {
        event = TEMP_ADD_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[5] == KE_PRESS && set_done == FALSE)
    {
        event = TEMP_REDUCE_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[4] == KE_LONG_PRESS && set_done == FALSE)
    {
        event = TEMP_ADD_FIVE_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[5] == KE_LONG_PRESS && set_done == FALSE)
    {
        event = TEMP_REDUCE_FIVE_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[6] == KE_PRESS && set_done == FALSE)
    {
        event = WIND_TIME_ADD_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[7] == KE_PRESS && set_done == FALSE)
    {
        event = WIND_TIME_REDUCE_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[6] == KE_LONG_PRESS && set_done == FALSE)
    {
        event = WIND_TIME_ADD_FIVE_EVENT;
        set_done = TRUE;
    }
    else if (key_event[7] == KE_LONG_PRESS && set_done == FALSE)
    {
        event = WIND_TIME_REDUCE_FIVE_EVENT ;
        set_done = TRUE;
    }
    else if (key_event[8] == KE_PRESS && set_done == FALSE)
    {
        event = TIME_COUNTDOWN_EVENT ;
        set_done = TRUE;
    }

    if (key_event[0] == KE_NONE && key_event[1] == KE_NONE && key_event[2] == KE_NONE && key_event[3] == KE_NONE
            && key_event[8] == KE_NONE  && key_event[9] == KE_NONE && set_done == TRUE)
    {
        set_done = FALSE;
    }

    /* ЪжБњАДМќ */
    if (!cold_mode)
    {
        if (key_event[11] != KE_NONE || key_event[10] != KE_NONE)
        {
            hel1_flag = 1;
            hel1_time = HEL_TIME;

            if (0 == hel1_mode)
            {
                if (key_event[11] == KE_PRESS)
                {
                    event = TEMP_ADD_EVENT ;
                }
                else if (key_event[11] == KE_LONG_PRESS)
                {
                    event = TEMP_ADD_FIVE_EVENT ;
                }
                else if (key_event[10] == KE_PRESS)
                {
                    event = TEMP_REDUCE_EVENT ;
                }
                else if (key_event[10] == KE_LONG_PRESS)
                {
                    event = TEMP_REDUCE_FIVE_EVENT ;
                }
            }
            else
            {
                if (key_event[11] == KE_PRESS)
                {
                    event = WIND_TIME_ADD_EVENT ;
                }
                else if (key_event[11] == KE_LONG_PRESS)
                {
                    event = WIND_TIME_ADD_FIVE_EVENT;
                }
                else if (key_event[10] == KE_PRESS)
                {
                    event = WIND_TIME_REDUCE_EVENT ;
                }
                else if (key_event[10] == KE_LONG_PRESS)
                {
                    event = WIND_TIME_REDUCE_FIVE_EVENT ;
                }
            }
        }

        if (hel1_flag)
        {
            if (key_event[9] == KE_PRESS)
            {
                hel1_time = HEL_TIME;
                hel1_mode = 1;
                refresh_set_wind_flag = 1;
                event = VALUE_RESET_EVENT;
            }

            hel1_time--;

            if (!hel1_time)
            {
                hel1_time = HEL_TIME;
                hel1_flag = 0;
                hel1_mode = 0;
            }
        }
        else
        {
            /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
            if (key_event[9] == KE_PRESS && !set_calibration_temp_flag  && set_done == FALSE && show_ch_value_flag == FALSE)
            {
                show_ch_value_flag = TRUE;
                ch++;

                if (ch >= 5)
                {
                    ch = 1;
                }

                if (ch == 1)
                {
                    set_temp = set_temp_ch1;
                    set_wind = set_wind_ch1;
                    set_time = set_time_ch1;
                    set_temp_f = (9 * set_temp / 5 + 32);
                }
                else if (ch == 2)
                {
                    set_temp = set_temp_ch2;
                    set_wind = set_wind_ch2;
                    set_time = set_time_ch2;
                    set_temp_f = (9 * set_temp / 5 + 32);
                }
                else if (ch == 3)
                {
                    set_temp = set_temp_ch3;
                    set_wind = set_wind_ch3;
                    set_time = set_time_ch2;
                    set_temp_f = (9 * set_temp / 5 + 32);
                }
                else if (ch == 4)
                {
                    set_temp = set_temp_ch4;
                    set_wind = set_wind_ch4;
                    set_time = set_time_ch2;
                    set_temp_f = (9 * set_temp / 5 + 32);
                }

                set_done = TRUE;
                event = VALUE_RESET_EVENT;
            }
            else if (key_event[9] == KE_LONG_PRESS)
            {
                cold_mode = 1;
                //beep_flag = BEEP_LONG;
            }
        }
    }
    else
    {
        if (key_event[9] == KE_PRESS)
        {
            cold_mode = 0;
        }
        else if (key_event[11] == KE_PRESS || key_event[6] == KE_PRESS)
        {
            if (cold_mode_set_wind >= 200)
            {
                cold_mode_set_wind = 200;
            }
            else
            {
                cold_mode_set_wind++;
            }
        }
        else if (key_event[11] == KE_LONG_PRESS || key_event[6] == KE_LONG_PRESS)
        {
            delay_time --;
            beep_flag = BEEP_SHORT;
            if (!delay_time)
            {
                delay_time = 5;

                if (cold_mode_set_wind >= 195)
                {
                    cold_mode_set_wind = 200;
                }
                else
                {
                    cold_mode_set_wind += 5;
                }
            }
        }
        else if (key_event[10] == KE_PRESS || key_event[7] == KE_PRESS)
        {
            if (cold_mode_set_wind <= 1)
            {
                cold_mode_set_wind = 1;
            }
            else
            {
                cold_mode_set_wind--;
            }
        }
        else if (key_event[10] == KE_LONG_PRESS || key_event[7] == KE_LONG_PRESS)
        {
            delay_time --;
            beep_flag = BEEP_SHORT;
            if (!delay_time)
            {
                delay_time = 5;

                if (cold_mode_set_wind <= 5)
                {
                    cold_mode_set_wind = 1;
                }
                else
                {
                    cold_mode_set_wind -= 5;
                }
            }
        }
    }

    /* ЪТМўДІРэ */
    if (swork.state != SLEEP && swork.state != COLD_MODE)//ЫЏУпФЃЪНКЭРфЗчФЃЪНЯТВЛЯьгІАДМќ
    {
        if (!set_temp_f && set_temp)
        {
            set_temp_f = (9 * set_temp / 5 + 32);
        }

        switch (event)
        {
        case TEMP_ADD_EVENT :

            /* ЮТЖШаЃзМЪБ */
            if (set_calibration_temp_flag)
            {
                if (external_temp >= set_temp + 50)
                {
                    external_temp = set_temp + 50;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        external_temp++;
                    }
                    else if (display_mode == 2)
                    {
                        if (external_temp_f >= (9 * (set_temp + 50) / 5 + 32))
                        {
                            external_temp_f = (9 * (set_temp + 50) / 5 + 32);
                        }
                        else
                        {
                            external_temp_f++;
                        }

                        external_temp = (external_temp_f - 32) * 5 / 9;
                    }
                }
            }
            else
            {
                if (set_temp >= 500)
                {
                    set_temp = 500;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        set_temp ++;
                    }
                    else if (display_mode == 2)
                    {
                        if (set_temp_f >= 932)
                        {
                            set_temp_f = 932;
                        }
                        else
                        {
                            set_temp_f++;
                        }

                        set_temp = (set_temp_f - 32) * 5 / 9;
                    }
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case TEMP_ADD_FIVE_EVENT:
            //delay_time --;
            beep_flag = BEEP_SHORT;

            //if (!delay_time)
            //{
            //delay_time = 2;

            /* ЮТЖШаЃзМЪБ */
            if (set_calibration_temp_flag)
            {
                if (external_temp >= set_temp + 45)
                {
                    external_temp = set_temp + 50;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        external_temp += 5;
                    }
                    else if (display_mode == 2)
                    {
                        if (external_temp_f >= (9 * (set_temp + 45) / 5 + 32))
                        {
                            external_temp_f = (9 * (set_temp + 45) / 5 + 32);
                        }
                        else
                        {
                            external_temp_f += 5;
                        }

                        external_temp = (external_temp_f - 32) * 5 / 9;
                    }
                }
            }
            else
            {
                if (set_temp >= 495)
                {
                    set_temp = 500;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        set_temp += 5;
                    }
                    else if (display_mode == 2)
                    {
                        if (set_temp_f >= 927)
                        {
                            set_temp_f = 932;
                        }
                        else
                        {
                            set_temp_f += 5;
                        }

                        set_temp = (set_temp_f - 32) * 5 / 9;
                    }
                }
            }

            //}
            event = VALUE_RESET_EVENT;
            break;

        case TEMP_REDUCE_EVENT :

            /* ЮТЖШаЃзМЪБ */
            if (set_calibration_temp_flag)
            {
                if (external_temp <= set_temp - 50)
                {
                    external_temp = set_temp - 50;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        external_temp --;
                    }
                    else if (display_mode == 2)
                    {
                        if (external_temp_f <= (9 * (set_temp - 50) / 5 + 32))
                        {
                            external_temp_f = (9 * (set_temp - 50) / 5 + 32);
                        }
                        else
                        {
                            external_temp_f --;
                        }

                        external_temp = (external_temp_f - 32) * 5 / 9;
                    }
                }
            }
            else
            {
                if (set_temp <= 100)
                {
                    set_temp = 100;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        set_temp --;
                    }
                    else if (display_mode == 2)
                    {
                        if (set_temp_f <= 212)
                        {
                            set_temp_f = 212;
                        }
                        else
                        {
                            set_temp_f --;
                        }

                        set_temp = (set_temp_f - 32) * 5 / 9;
                    }
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case TEMP_REDUCE_FIVE_EVENT:
            //delay_time --;
            beep_flag = BEEP_SHORT;

            //if (!delay_time)
            //{
            //delay_time = 2;
            /* ЮТЖШаЃзМЪБ */
            if (set_calibration_temp_flag)
            {
                if (external_temp <= set_temp - 50)
                {
                    external_temp = set_temp - 50;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        external_temp --;
                    }
                    else if (display_mode == 2)
                    {
                        if (external_temp_f <= (9 * (set_temp - 45) / 5 + 32))
                        {
                            external_temp_f = (9 * (set_temp - 45) / 5 + 32);
                        }
                        else
                        {
                            external_temp_f -= 5;
                        }

                        external_temp = (external_temp_f - 32) * 5 / 9;
                    }
                }
            }
            else
            {
                if (set_temp <= 100)
                {
                    set_temp = 100;
                }
                else
                {
                    if (display_mode == 1)
                    {
                        set_temp  -= 5;
                    }
                    else if (display_mode == 2)
                    {
                        if (set_temp_f <= 216)
                        {
                            set_temp_f = 212;
                        }
                        else
                        {
                            set_temp_f  -= 5;
                        }

                        set_temp = (set_temp_f - 32) * 5 / 9;
                    }
                }
            }

            //}
            event = VALUE_RESET_EVENT;
            break;

        case WIND_TIME_ADD_EVENT:
            if (set_time_flag)
            {
                if (set_time >= 999)
                {
                    set_time = 1;
                }
                else
                {
                    set_time++;
                }
            }
            else
            {
                if (set_wind >= 200)
                {
                    set_wind = 200;
                }
                else
                {
                    set_wind++;
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case WIND_TIME_ADD_FIVE_EVENT:
            delay_time--;
            beep_flag = BEEP_SHORT;

            if (!delay_time)
            {
                delay_time = 5;

                if (set_time_flag)
                {
                    if (set_time >= 995)
                    {
                        set_time = 1;
                    }
                    else
                    {
                        set_time += 5;
                    }
                }
                else
                {
                    if (set_wind >= 195)
                    {
                        set_wind = 200;
                    }
                    else
                    {
                        set_wind += 5;
                    }
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case WIND_TIME_REDUCE_EVENT:
            if (set_time_flag)
            {
                if (set_time <= 0)
                {
                    set_time = 0;
                }
                else
                {
                    set_time--;
                }
            }
            else
            {
                if (set_wind <= 1)
                {
                    set_wind = 1;
                }
                else
                {
                    set_wind--;
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case WIND_TIME_REDUCE_FIVE_EVENT:
            delay_time --;
            beep_flag = BEEP_SHORT;

            if (!delay_time)
            {
                delay_time = 5;

                if (set_time_flag)
                {
                    if (set_time <= 5)
                    {
                        set_time = 0;
                    }
                    else
                    {
                        set_time -= 5;
                    }
                }
                else
                {
                    if (set_wind <= 4)
                    {
                        set_wind = 1;
                    }
                    else
                    {
                        set_wind  -= 5;
                    }
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case TIME_COUNTDOWN_EVENT://setБЛЖЬАД
            if (set_calibration_temp_flag == TRUE) //ШчЙће§дкЩшжУаЃзМЮТЖШ
            {
                set_calibration_temp_flag = FALSE;//ЭЫГіаЃзМФЃЪН
            }
            else
            {
                if (set_time_flag) //ЯШЭЫГіЩшжУФЃЪН
                {
                    set_time_flag = 0;
                }
                else if (time_countdown_flag) //ШчЙћвбО­ПЊЪМЕЙМЦЪБОЭЭЃжЙЕЙМЦЪБ
                {
                    time_countdown_flag = 0;
                    beep_flag = BEEP_LONG;
                }
                else if (!set_time_flag && swork.state == WORKING) //ШчЙћУЛПЊЪМЕЙМЦЪБЧвВЛЪЧдкЩшжУЪБМфФЃЪНОЭПЊЪМЕЙМЦЪБ
                {
                    time_countdown_flag = 1;
                }
            }

            event = VALUE_RESET_EVENT;
            break;

        case SET_TIME_EVENT://setБЛГЄАД
            set_time_flag = 1;
            event = VALUE_RESET_EVENT;
            break;

        case SET_CH1_EVENT://ch1БЛГЄАД
            if (!set_calibration_temp_flag)
            {
                save_ch_flag = 1;
                set_temp_ch1 = set_temp;
                set_wind_ch1 = set_wind;
                set_time_ch1 = set_time;
                beep_flag = BEEP_LONG;
                set_done = TRUE;
                event = VALUE_RESET_EVENT;
            }

            break;

        case SET_CH2_EVENT://ch2БЛГЄАД

            /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
            if (!set_calibration_temp_flag)
            {
                save_ch_flag = 2;
                set_temp_ch2 = set_temp;
                set_wind_ch2 = set_wind;
                set_time_ch2 = set_time;
                beep_flag = BEEP_LONG;
                set_done = TRUE;
                event = VALUE_RESET_EVENT;
            }

            break;

        case SET_CH3_EVENT://ch3БЛГЄАД

            /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
            if (!set_calibration_temp_flag)
            {
                save_ch_flag = 3;
                set_temp_ch3 = set_temp;
                set_wind_ch3 = set_wind;
                set_time_ch3 = set_time;
                beep_flag = BEEP_LONG;
                set_done = TRUE;
                event = VALUE_RESET_EVENT;
            }

            break;

        case SET_CH4_EVENT://ch4БЛГЄАД

            /* аЃзМЮТЖШЪБВЛдЪаэБЛДђЖЯ */
            if (!set_calibration_temp_flag)
            {
                save_ch_flag = 4;
                set_temp_ch4 = set_temp;
                set_wind_ch4 = set_wind;
                set_time_ch4 = set_time;
                beep_flag = BEEP_LONG;
                set_done = TRUE;
                event = VALUE_RESET_EVENT;
            }

            break;

        case VALUE_RESET_EVENT:
            swork.sleep_time = 0;
            event = END_EVENT;
            break;

        case SYSTEM_RESET_EVENT:
            /* ЛжИДЭЈЕРФЌШЯжЕ */
                set_temp = 300;
                set_time = 40;
                set_wind = 20;
                set_temp_ch1 = 300;
                set_wind_ch1 = 40;
                set_time_ch1 = 20;
                set_temp_ch2 = 320;
                set_wind_ch2 = 50;
                set_time_ch3 = 30;
                set_temp_ch3 = 350;
                set_wind_ch3 = 60;
                set_time_ch3 = 30;
                set_temp_ch4 = 380;
                set_wind_ch4 = 80;
                set_time_ch4 = 60;
                display_mode = 1;
                speak_mode = 1;
                lock_mode = 1;
                cold_mode_set_wind = 100;
                set_calibration_temp = 0;
            swork.sleep_time = 0;
            beep_flag = BEEP_LONG;
            event = END_EVENT;
            break;

        case END_EVENT:
            break;
        }
    }
}