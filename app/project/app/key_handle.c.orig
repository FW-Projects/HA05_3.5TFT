#include "key_handle.h"
#include "work_handle.h"
#include "PID_operation.h"
extern uint8_t beep_flag;


static KEY_VALUE get_key_ch1()
{
    if (READ_CH1_KEY == 0)
    {
        return K_PRESS;
    }
    else
    {
        return K_RELEASE;
    }
}

static KEY_VALUE get_key_ch2()
{
    if (READ_CH2_KEY == 0)
    {
        return K_PRESS;
    }
    else
    {
        return K_RELEASE;
    }
}

