#include "work_handle.h"
#include "lcd_handle.h"
#include "PID_operation.h"
extern uint8_t beep_flag;
work_handle_t swork =
{
    .state = INIT,
    .sleep_time = 0,
    .error_time = 0,
    .beep_open = 0,
};

void WorkProc(void)
{
	
    switch (swork.state)
    {
    case INIT:
        if (!gpio_input_data_bit_read(GPIOA, GPIO_PINS_8))
        {
            swork.state = STOP;
            break;
        }
        else
        {
            //swork.state = INIT;
            swork.state = WORKING;
			break;
        }
		
		        if (actual_temp <= 50 || actual_temp >= 380)
        {
            swork.error_time++;

            if (swork.error_time >= ERROR_TIME_OUT)
            {
                if (actual_temp <= 50)
                {
                    swork.state = LOW_TEMP_ERR;
                    break;
                }
                else
                {
                    swork.state = OVER_TEMP_ERR;
                    break;
                }
            }
        }
        else
        {
            swork.error_time = 0;
        }

    case STOP:

	        if (actual_temp <= 50 || actual_temp >= 380)
        {
            swork.error_time++;

            if (swork.error_time >= ERROR_TIME_OUT)
            {
                if (actual_temp <= 50)
                {
                    swork.state = LOW_TEMP_ERR;
                    break;
                }
                else
                {
                    swork.state = OVER_TEMP_ERR;
                    break;
                }
            }
        }
        else
        {
            swork.error_time = 0;
        }
		swork.error_time = 0;
        if (!gpio_input_data_bit_read(GPIOA, GPIO_PINS_8))
        {
            if (actual_temp <= 70)
            {
                swork.sleep_time ++;

                if (swork.sleep_time >= 4)
                {
                    swork.sleep_time = 0;
                    beep_flag = BEEP_LONG;
                    swork.state = SLEEP;
                    break;
                }
            }
            else
            {
                swork.sleep_time = 0;
            }

            swork.state = STOP;
            break;
        }
        else
			
        {
            swork.state = WORKING;
            break;
        }

    case WORKING:
        /*  ·ŔÖą»­ĂćËşÁŃ Őâ˛ż·ÖÔÚLCDÖĐ×öżŘÖĆ */
        //        if (cold_mode == 1)
        //        {
        //            swork.state = COLD_MODE;
        //            break;
        //        }

        if (actual_temp <= 50 || actual_temp >= 380)
        {
            swork.error_time++;

            if (swork.error_time >= ERROR_TIME_OUT)
            {
                if (actual_temp <= 50)
                {
                    swork.state = LOW_TEMP_ERR;
                    break;
                }
                else
                {
                    swork.state = OVER_TEMP_ERR;
                    break;
                }
            }
        }
        else
        {
            swork.error_time = 0;
        }

        if (!gpio_input_data_bit_read(GPIOA, GPIO_PINS_8))
        {
            swork.state = STOP;
            break;
        }
        else
        {
            swork.state = WORKING;
            break;
        }

    case SLEEP:
	
        if (actual_temp <= 50 || actual_temp >= 380)
        {
            swork.error_time++;

            if (swork.error_time >= ERROR_TIME_OUT)
            {
                if (actual_temp <= 50)
                {
                    swork.state = LOW_TEMP_ERR;
                    break;
                }
                else
                {
                    swork.state = OVER_TEMP_ERR;
                    break;
                }
            }
        }
        else
        {
            swork.error_time = 0;
        }	
	
        if (gpio_input_data_bit_read(GPIOA, GPIO_PINS_8))
        {
            swork.state = WORKING;
            break;
        }
        break;

    case OVER_TEMP_ERR:
        break;

    case LOW_TEMP_ERR:
        break;

    case COLD_MODE:
		
		swork.error_time = 0;
        if (cold_mode == FALSE)
        {
            if (gpio_input_data_bit_read(GPIOA, GPIO_PINS_8))
            {
                swork.state = WORKING;
                break;
            }
            else
            {
                swork.state = STOP;
                break;
            }
        }
    }
}
