#include "flash_handle.h"
#include "lcd_handle.h"

uint16_t data_check(uint32_t address)
{
    static uint16_t data;
    data = flash_wred_halfword(address);

    if (data == 0xffff)
    {
        return FALSE;
    }
    else
    {
        return data;
    }
}


uint16_t data_check_len(uint32_t address, uint8_t len)
{
    volatile uint16_t data;
    uint8_t i;

    for (i = 0; i < len; i += DATA_SIZE)
    {
        data = flash_wred_halfword(address + i);

        if (data == 0xFFFF)
        {
            break;
        }
    }

    return data;
}



void FlashProc(void)
{
    static flash_handle_t sflash;
    static uint16_t last_set_temp;
    static uint16_t last_set_wind;
    static uint16_t last_set_time;
    static uint16_t last_ch1_set_temp;
    static uint16_t last_ch1_set_wind;
    static uint16_t last_ch1_set_time;
    static uint16_t last_ch2_set_temp;
    static uint16_t last_ch2_set_wind;
    static uint16_t last_ch2_set_time;
    static uint16_t last_ch3_set_temp;
    static uint16_t last_ch3_set_wind;
    static uint16_t last_ch3_set_time;
    static uint16_t last_ch4_set_temp;
    static uint16_t last_ch4_set_wind;
    static uint16_t last_ch4_set_time;
    static uint16_t last_display_mode;
    static uint16_t last_speak_mode;
    static uint8_t last_lock_mode;
    static uint16_t last_cold_mode_set_wind;
    static int16_t last_set_calibration_temp;
    static uint16_t flash_version = 0;
    static uint8_t flash_count = 0;
    static uint8_t first_start_flag = FALSE;
    static uint16_t a_ver;
    static uint16_t b_ver;

    switch (sflash.state)
    {
    case FLASH_START:
        if (FALSE == first_start_flag)
        {
            /* Ľě˛âÖ÷´ć´˘ÇřşÍ±¸·Ý´ć´˘ÇřĘýľÝ */
            if (data_check_len(LAST_SYSTEM_SET_TEMP_ADDRESS, FLASH_MENBER) != 0xFFFF
                    && data_check_len(LAST_SYSTEM_SET_TEMP_ADDRESS, FLASH_MENBER) != 0xFFFF)
            {
                /* Ľě˛éÄÄ¸öÇřµÄĘýľÝ×îĐÂ */
                a_ver = flash_wred_halfword(FLASH_VERSION_ADDRESS);
                b_ver = flash_wred_halfword(BACKUPS_FLASH_VERSION_ADDRESS);

                if (a_ver > b_ver)
                {
                    set_temp = flash_wred_halfword(LAST_SYSTEM_SET_TEMP_ADDRESS);
                    set_wind = flash_wred_halfword(LAST_SYSTEM_SET_WIND_ADDRESS);
                    set_time = flash_wred_halfword(LAST_SYSTEM_SET_TIME_ADDRESS);
                    set_temp_ch1 = flash_wred_halfword(CH1_SET_TEMP_ADDRESS);
                    set_wind_ch1 = flash_wred_halfword(CH1_SET_WIND_ADDRESS);
                    set_time_ch1 = flash_wred_halfword(CH1_SET_TIME_ADDRESS);
                    set_temp_ch2 = flash_wred_halfword(CH2_SET_TEMP_ADDRESS);
                    set_wind_ch2 = flash_wred_halfword(CH2_SET_WIND_ADDRESS);
                    set_time_ch2 = flash_wred_halfword(CH2_SET_TIME_ADDRESS);
                    set_temp_ch3 = flash_wred_halfword(CH3_SET_TEMP_ADDRESS);
                    set_wind_ch3 = flash_wred_halfword(CH3_SET_WIND_ADDRESS);
                    set_time_ch3 = flash_wred_halfword(CH3_SET_TIME_ADDRESS);
                    set_temp_ch4 = flash_wred_halfword(CH4_SET_TEMP_ADDRESS);
                    set_wind_ch4 = flash_wred_halfword(CH4_SET_WIND_ADDRESS);
                    set_time_ch4 = flash_wred_halfword(CH4_SET_TIME_ADDRESS);
                    display_mode = flash_wred_halfword(LAST_DISPLAY_MODE_ADDRESS);
                    speak_mode   = flash_wred_halfword(LAST_SPEAK_MODE_ADDRESS);
                    lock_mode    = flash_wred_halfword(LAST_LOCK_MODE_ADDRESS);
                    cold_mode_set_wind = flash_wred_halfword(LAST_COLE_MODE_SET_WIND_ADDRESS);
                    set_calibration_temp = flash_wred_halfword(TEMP_CALIBRATION_ADDRESS);
                }
                else
                {
                    set_temp = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_TEMP_ADDRESS);
                    set_wind = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_WIND_ADDRESS);
                    set_time = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_TIME_ADDRESS);
                    set_temp_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_TEMP_ADDRESS);
                    set_wind_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_WIND_ADDRESS);
                    set_time_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_TIME_ADDRESS);
                    set_temp_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_TEMP_ADDRESS);
                    set_wind_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_WIND_ADDRESS);
                    set_time_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_TIME_ADDRESS);
                    set_temp_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_TEMP_ADDRESS);
                    set_wind_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_WIND_ADDRESS);
                    set_time_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_TIME_ADDRESS);
                    set_temp_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_TEMP_ADDRESS);
                    set_wind_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_WIND_ADDRESS);
                    set_time_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_TIME_ADDRESS);
                    display_mode = flash_wred_halfword(BACKUPS_LAST_DISPLAY_MODE_ADDRESS);
                    speak_mode   = flash_wred_halfword(BACKUPS_LAST_SPEAK_MODE_ADDRESS);
                    lock_mode    = flash_wred_halfword(BACKUPS_LAST_LOCK_MODE_ADDRESS);
                    cold_mode_set_wind = flash_wred_halfword(BACKUPS_LAST_COLE_MODE_SET_WIND_ADDRESS);
                    set_calibration_temp = flash_wred_halfword(BACKUPS_TEMP_CALIBRATION_ADDRESS);
                }
            }
            /* Ľě˛éÖ÷´˘ÇřĘýľÝ */
            else if (data_check_len(LAST_SYSTEM_SET_TEMP_ADDRESS, FLASH_MENBER) != 0xFFFF)
            {
                set_temp = flash_wred_halfword(LAST_SYSTEM_SET_TEMP_ADDRESS);
                set_wind = flash_wred_halfword(LAST_SYSTEM_SET_WIND_ADDRESS);
                set_time = flash_wred_halfword(LAST_SYSTEM_SET_TIME_ADDRESS);
                set_temp_ch1 = flash_wred_halfword(CH1_SET_TEMP_ADDRESS);
                set_wind_ch1 = flash_wred_halfword(CH1_SET_WIND_ADDRESS);
                set_time_ch1 = flash_wred_halfword(CH1_SET_TIME_ADDRESS);
                set_temp_ch2 = flash_wred_halfword(CH2_SET_TEMP_ADDRESS);
                set_wind_ch2 = flash_wred_halfword(CH2_SET_WIND_ADDRESS);
                set_time_ch2 = flash_wred_halfword(CH2_SET_TIME_ADDRESS);
                set_temp_ch3 = flash_wred_halfword(CH3_SET_TEMP_ADDRESS);
                set_wind_ch3 = flash_wred_halfword(CH3_SET_WIND_ADDRESS);
                set_time_ch3 = flash_wred_halfword(CH3_SET_TIME_ADDRESS);
                set_temp_ch4 = flash_wred_halfword(CH4_SET_TEMP_ADDRESS);
                set_wind_ch4 = flash_wred_halfword(CH4_SET_WIND_ADDRESS);
                set_time_ch4 = flash_wred_halfword(CH4_SET_TIME_ADDRESS);
                display_mode = flash_wred_halfword(LAST_DISPLAY_MODE_ADDRESS);
                speak_mode   = flash_wred_halfword(LAST_SPEAK_MODE_ADDRESS);
                lock_mode    = flash_wred_halfword(LAST_LOCK_MODE_ADDRESS);
                cold_mode_set_wind = flash_wred_halfword(LAST_COLE_MODE_SET_WIND_ADDRESS);
                set_calibration_temp = flash_wred_halfword(TEMP_CALIBRATION_ADDRESS);
            }
            /* Ľě˛é±¸·Ý´ć´˘ÇřĘýľÝ */
            else if (data_check_len(BACKUPS_LAST_SYSTEM_SET_TEMP_ADDRESS, FLASH_MENBER) != 0xFFFF)
            {
                set_temp = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_TEMP_ADDRESS);
                set_wind = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_WIND_ADDRESS);
                set_time = flash_wred_halfword(BACKUPS_LAST_SYSTEM_SET_TIME_ADDRESS);
                set_temp_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_TEMP_ADDRESS);
                set_wind_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_WIND_ADDRESS);
                set_time_ch1 = flash_wred_halfword(BACKUPS_CH1_SET_TIME_ADDRESS);
                set_temp_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_TEMP_ADDRESS);
                set_wind_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_WIND_ADDRESS);
                set_time_ch2 = flash_wred_halfword(BACKUPS_CH2_SET_TIME_ADDRESS);
                set_temp_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_TEMP_ADDRESS);
                set_wind_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_WIND_ADDRESS);
                set_time_ch3 = flash_wred_halfword(BACKUPS_CH3_SET_TIME_ADDRESS);
                set_temp_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_TEMP_ADDRESS);
                set_wind_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_WIND_ADDRESS);
                set_time_ch4 = flash_wred_halfword(BACKUPS_CH4_SET_TIME_ADDRESS);
                display_mode = flash_wred_halfword(BACKUPS_LAST_DISPLAY_MODE_ADDRESS);
                speak_mode   = flash_wred_halfword(BACKUPS_LAST_SPEAK_MODE_ADDRESS);
                lock_mode    = flash_wred_halfword(BACKUPS_LAST_LOCK_MODE_ADDRESS);
                cold_mode_set_wind = flash_wred_halfword(BACKUPS_LAST_COLE_MODE_SET_WIND_ADDRESS);
                set_calibration_temp = flash_wred_halfword(BACKUPS_TEMP_CALIBRATION_ADDRESS);
            }
            else
            {
                set_temp = 300;
                set_time = 40;
                set_wind = 20;
				
                set_temp_ch1 = 300;
                set_wind_ch1 = 40;
                set_time_ch1 = 30;
				
                set_temp_ch2 = 320;
                set_wind_ch2 = 50;
				set_time_ch2 = 40;
				
                set_temp_ch3 = 350;
                set_wind_ch3 = 60;
                set_time_ch3 = 50;
				
                set_temp_ch4 = 380;
                set_wind_ch4 = 80;
                set_time_ch4 = 60;
                display_mode = 1;
                speak_mode = 1;
                lock_mode = 1;
                cold_mode_set_wind = 100;
                set_calibration_temp = 0;
            }

			if(set_temp >500 || set_temp<100 )
				set_temp = 300;
			if(set_time >999 || set_time<0 )
				set_time = 40;
			if(set_wind >200 || set_wind<1 )
				set_wind = 20;
			
			
			if(set_temp_ch1 >500 || set_temp_ch1<100 )
				set_temp_ch1 = 300;
			if(set_time_ch1 >999 || set_time_ch1<0 )
				set_time_ch1 = 40;
			if(set_wind_ch1 >200 || set_wind<1 )
				set_wind_ch1 = 30;
			
			
			if(set_temp_ch2 >500 || set_temp_ch2<100 )
				set_temp_ch2 = 320;
			if(set_time_ch2 >999 || set_time_ch2<0 )
				set_time_ch2 = 50;
			if(set_wind_ch2 >200 || set_wind<1 )
				set_wind_ch2 = 40;
			
			
			if(set_temp_ch3 >500 || set_temp_ch3<100 )
				set_temp_ch3 = 350;
			if(set_time_ch3 >999 || set_time_ch3<0 )
				set_time_ch3 = 60;
			if(set_wind_ch3 >200 || set_wind<1 )
				set_wind_ch3 = 50;
			
			if(set_temp_ch4 >500 || set_temp_ch4<100 )
				set_temp_ch4 = 380;
			if(set_time_ch4 >999 || set_time_ch4<0 )
				set_time_ch4 = 80;
			if(set_wind_ch4 >200 || set_wind<1 )
				set_wind_ch4 = 60;			
			
			if(speak_mode >2 || speak_mode<1)
				speak_mode = 1;
			
			if(lock_mode >2 || lock_mode<1)
				lock_mode = 1;

			if(cold_mode_set_wind>200 || cold_mode_set_wind<0)
			cold_mode_set_wind = 100;
            last_set_temp     = set_temp;
            last_set_time     = set_time;
            last_set_wind     = set_wind;
            last_ch1_set_temp = set_temp_ch1;
            last_ch1_set_wind = set_wind_ch1;
            last_ch1_set_time = set_time_ch1;
            last_ch2_set_temp = set_temp_ch2;
            last_ch2_set_wind = set_wind_ch2;
            last_ch2_set_time = set_time_ch2;
            last_ch3_set_temp = set_temp_ch3;
            last_ch3_set_wind = set_wind_ch3;
            last_ch3_set_time = set_time_ch3;
            last_ch4_set_temp = set_temp_ch4;
            last_ch4_set_wind = set_wind_ch4;
            last_ch4_set_time = set_time_ch4;
            last_display_mode = display_mode;
            last_speak_mode   = speak_mode;
            last_lock_mode    = lock_mode;
            last_cold_mode_set_wind = cold_mode_set_wind;
            last_set_calibration_temp = set_calibration_temp;
            first_start_flag  = TRUE;
        }
        else
        {
            sflash.state = FLASH_SET_TEMP;
            break;
        }

        break;

    case FLASH_SET_TEMP:
        if (last_set_temp != set_temp ||
                last_set_wind != set_wind ||
                last_ch1_set_temp != set_temp_ch1 ||
                last_ch1_set_wind != set_wind_ch1 ||
                last_ch1_set_time != set_time_ch1 ||
                last_ch2_set_temp != set_temp_ch2 ||
                last_ch2_set_wind != set_wind_ch2 ||
                last_ch2_set_time != set_time_ch2 ||
                last_ch3_set_temp != set_temp_ch3 ||
                last_ch3_set_wind != set_wind_ch3 ||
                last_ch3_set_time != set_time_ch3 ||
                last_ch4_set_temp != set_temp_ch4 ||
                last_ch4_set_wind != set_wind_ch4 ||
                last_ch4_set_time != set_time_ch4 ||
                last_set_time     != set_time     ||
                last_display_mode != display_mode ||
                last_speak_mode   != speak_mode   ||
                last_lock_mode    != lock_mode    ||
                last_cold_mode_set_wind != cold_mode_set_wind ||
                last_set_calibration_temp != set_calibration_temp)
        {
            flash_unlock();

            if (flash_count % 2 != FALSE)
            {
                flash_sector_erase(LAST_SYSTEM_SET_TEMP_ADDRESS);
                flash_halfword_program(LAST_SYSTEM_SET_TEMP_ADDRESS, set_temp);
            }
            else
            {
                flash_sector_erase(BACKUPS_LAST_SYSTEM_SET_TEMP_ADDRESS);
                flash_halfword_program(BACKUPS_LAST_SYSTEM_SET_TEMP_ADDRESS, set_temp);
            }

            last_set_temp = set_temp;
            sflash.state ++;
            break;
        }

        break;

    case FLASH_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_SYSTEM_SET_WIND_ADDRESS, set_wind);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_SYSTEM_SET_WIND_ADDRESS, set_wind);
        }

        last_set_wind = set_wind;
        sflash.state ++;
        break;

    case FLASH_CH1_SET_TEMP:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH1_SET_TEMP_ADDRESS, set_temp_ch1);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH1_SET_TEMP_ADDRESS, set_temp_ch1);
        }

        last_ch1_set_temp = set_temp_ch1;
        sflash.state ++;
        break;

    case FLASH_CH1_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH1_SET_WIND_ADDRESS, set_wind_ch1);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH1_SET_WIND_ADDRESS, set_wind_ch1);
        }

        last_ch1_set_wind = set_wind_ch1;
        sflash.state++;
        break;

    case FLASH_CH1_SET_TIME:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH1_SET_TIME_ADDRESS, set_time_ch1);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH1_SET_TIME_ADDRESS, set_time_ch1);
        }

        last_ch1_set_time = set_time_ch1;
        sflash.state++;
        break;

    case FLASH_CH2_SET_TEMP:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH2_SET_TEMP_ADDRESS, set_temp_ch2);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH2_SET_TEMP_ADDRESS, set_temp_ch2);
        }

        last_ch2_set_temp = set_temp_ch2;
        sflash.state++;
        break;

    case FLASH_CH2_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH2_SET_WIND_ADDRESS, set_wind_ch2);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH2_SET_WIND_ADDRESS, set_wind_ch2);
        }

        last_ch2_set_wind = set_wind_ch2;
        sflash.state++;
        break;

    case FLASH_CH2_SET_TIME:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH2_SET_TIME_ADDRESS, set_time_ch2);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH2_SET_TIME_ADDRESS, set_time_ch2);
        }

        last_ch2_set_time = set_time_ch2;
        sflash.state++;
        break;

    case FLASH_CH3_SET_TEMP:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH3_SET_TEMP_ADDRESS, set_temp_ch3);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH3_SET_TEMP_ADDRESS, set_temp_ch3);
        }

        last_ch3_set_temp = set_temp_ch3;
        sflash.state++;
        break;

    case FLASH_CH3_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH3_SET_WIND_ADDRESS, set_wind_ch3);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH3_SET_WIND_ADDRESS, set_wind_ch3);
        }

        last_ch3_set_wind = set_wind_ch3;
        sflash.state++;
        break;

    case FLASH_CH3_SET_TIME:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH3_SET_TIME_ADDRESS, set_time_ch3);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH3_SET_TIME_ADDRESS, set_time_ch3);
        }

        last_ch3_set_time = set_time_ch3;
        sflash.state++;
        break;

    case FLASH_CH4_SET_TEMP:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH4_SET_TEMP_ADDRESS, set_temp_ch4);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH4_SET_TEMP_ADDRESS, set_temp_ch4);
        }

        last_ch4_set_temp = set_temp_ch4;
        sflash.state++;
        break;

    case FLASH_CH4_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH4_SET_WIND_ADDRESS, set_wind_ch4);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH4_SET_WIND_ADDRESS, set_wind_ch4);
        }

        last_ch4_set_wind = set_wind_ch4;
        sflash.state  ++;
        break;

    case FLASH_CH4_SET_TIME:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(CH4_SET_TIME_ADDRESS, set_time_ch4);
        }
        else
        {
            flash_halfword_program(BACKUPS_CH4_SET_TIME_ADDRESS, set_time_ch4);
        }

        last_ch4_set_time = set_time_ch4;
        sflash.state++;
        break;

    case FLASH_SET_TIME:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_SYSTEM_SET_TIME_ADDRESS, set_time);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_SYSTEM_SET_TIME_ADDRESS, set_time);
        }

        last_set_time = set_time;
        sflash.state++;
        break;

    case FLASH_DISPLAY_MODE:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_DISPLAY_MODE_ADDRESS, display_mode);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_DISPLAY_MODE_ADDRESS, display_mode);
        }

        last_display_mode = display_mode;
        sflash.state++;
        break;

    case FLASH_SPEAK_MODE:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_SPEAK_MODE_ADDRESS, speak_mode);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_SPEAK_MODE_ADDRESS, speak_mode);
        }

        last_speak_mode = speak_mode;
        sflash.state++;
        break;

    case FLASH_LOCK_MODE:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_LOCK_MODE_ADDRESS, lock_mode);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_LOCK_MODE_ADDRESS, lock_mode);
        }

        last_lock_mode = lock_mode;
        sflash.state ++;
        break;

    case FLASH_COLD_MODE_SET_WIND:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(LAST_COLE_MODE_SET_WIND_ADDRESS, cold_mode_set_wind);
        }
        else
        {
            flash_halfword_program(BACKUPS_LAST_COLE_MODE_SET_WIND_ADDRESS, cold_mode_set_wind);
        }

        last_cold_mode_set_wind = cold_mode_set_wind;
        sflash.state ++;
        break;

    case FLASH_TEMP_CALIBRATION:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(TEMP_CALIBRATION_ADDRESS, set_calibration_temp);
        }
        else
        {
            flash_halfword_program(BACKUPS_TEMP_CALIBRATION_ADDRESS, set_calibration_temp);
        }

        last_set_calibration_temp = set_calibration_temp;
        sflash.state ++;
        break;

    case FLASH_VER:
        if (flash_count % 2 != FALSE)
        {
            flash_halfword_program(FLASH_VERSION_ADDRESS, flash_version);
        }
        else
        {
            flash_halfword_program(BACKUPS_FLASH_VERSION_ADDRESS, flash_version);
        }

        sflash.state ++;
        break;

    case FLASH_FINSH:
        flash_lock();
        flash_version++;
        flash_count++;
        sflash.state = FLASH_START;
        break;
    }
}
