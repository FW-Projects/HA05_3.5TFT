#include "key.h"
extern uint8_t beep_flag;
KEY_EVENT key_event_check(KEY *key, int interval)
{
    static KEY_EVENT key_event = KE_NONE;
    static int key_cycle_time = KEY_CYCLE_TIME;

    switch (key->status)
    {
    case KS_RELEASE:
    {
        key->count = 0;

        if (key->get() == K_PRESS)
        {
            //key->status = KS_SHAKE;
            key->status = KS_CHECK;
        }
        else
        {
            key_event = KE_NONE;
            key->status = KS_RELEASE;
        }
    }
    break;

    //    case KS_SHAKE:
    //    {
    //        if (key->get() == K_PRESS)
    //        {
    //            key->status = KS_CHECK;
    //        }
    //        else
    //        {
    //            key->status = KS_RELEASE;
    //        }/
    //    }
    //    break;

    case KS_CHECK:
    {
        key_cycle_time--;
        if (!key_cycle_time)
        {
            key_cycle_time = KEY_CYCLE_TIME;

            if (key->count >= interval)
            {
                key->status = KS_LONG_PRESS;
                break;
            }
            else
            {
                key->status = KS_PRESS;
                break;
            }
        }

        if (key->get() == K_PRESS)
        {
            key->count += 1;
        }
    }
    break;

    case KS_LONG_PRESS:
    {
        if (key->get() == K_PRESS)
        {
            key->status = KS_LONG_PRESS;
            key_event = KE_LONG_PRESS;
            //beep_flag = 1;
        }
        else
        {
            key->status = KS_RELEASE;
        }
    }
    break;

    case KS_PRESS:
    {
        key_event = KE_PRESS;
        key->status = KS_RELEASE;
        beep_flag = 1;
    }
    break;
    }

    return key_event;
}
