#ifndef _KEY_H
#define _KEY_H

#include <stdio.h>
#include "at32f415.h"

/* input */
#define CH1_KEY_PORT             GPIOC
#define CH1_KEY_PIN              GPIO_PINS_6
#define READ_CH1_KEY             gpio_input_data_bit_read(CH1_KEY_PORT, CH1_KEY_PIN)

#define CH2_KEY_PORT             GPIOC
#define CH2_KEY_PIN              GPIO_PINS_9
#define READ_CH2_KEY             gpio_input_data_bit_read(CH2_KEY_PORT, CH2_KEY_PIN)

#define CH3_KEY_PORT             GPIOC
#define CH3_KEY_PIN              GPIO_PINS_3
#define READ_CH3_KEY             gpio_input_data_bit_read(CH3_KEY_PORT, CH3_KEY_PIN)

#define CH4_KEY_PORT             GPIOC
#define CH4_KEY_PIN              GPIO_PINS_4
#define READ_CH4_KEY             gpio_input_data_bit_read(CH4_KEY_PORT, CH4_KEY_PIN)

#define TEMP_ADD_KEY_PORT        GPIOC
#define TEMP_ADD_KEY_PIN         GPIO_PINS_7
#define READ_EMP_ADD_KEY         gpio_input_data_bit_read(TEMP_ADD_KEY_PORT, TEMP_ADD_KEY_PIN)

#define TEMP_REDUCE_KEY_PORT     GPIOC
#define TEMP_REDUCE_KEY_PIN      GPIO_PINS_8
#define READ_TEMP_REDUCE_KEY     gpio_input_data_bit_read(TEMP_REDUCE_KEY_PORT, TEMP_REDUCE_KEY_PIN)

#define AIR_ADD_KEY_PORT         GPIOC
#define AIR_ADD_KEY_PIN          GPIO_PINS_1
#define READ_AIR_ADD_KEY         gpio_input_data_bit_read(AIR_ADD_KEY_PORT, AIR_ADD_KEY_PIN)

#define AIR_REDUCE_KEY_PORT      GPIOC
#define AIR_REDUCE_KEY_PIN       GPIO_PINS_2
#define READ_AIR_REDUCE_KEY      gpio_input_data_bit_read(AIR_REDUCE_KEY_PORT, AIR_REDUCE_KEY_PIN)

#define SET_KEY_PORT             GPIOC
#define SET_KEY_PIN              GPIO_PINS_5
#define READ_SET_KEY             gpio_input_data_bit_read(SET_KEY_PORT, SET_KEY_PIN)

#define KEY_SCAN_TIME                100


#ifdef __cplusplus
extern "C" {
#endif

typedef enum {
    K_RELEASE,
    K_PRESS,
} KEY_VALUE;

typedef enum {
    KS_RELEASE,
    KS_SHAKE,
    KS_PRESS,
} KEY_STATUS;

typedef enum {
    KE_PRESS,
    KE_RELEASE,
    KE_LONG_PRESS,
    KE_LONG_RELEASE,
    KE_NONE,
} KEY_EVENT;

typedef struct {
    KEY_STATUS status;
    int count;
    KEY_VALUE (*get)(void);
} KEY;

KEY_EVENT key_event_check(KEY *key, int interval);

#ifdef __cplusplus
}
#endif
#endif


